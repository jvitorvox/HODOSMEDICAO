# ══════════════════════════════════════════════════════════════
# HAMOA OBRAS — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores
# NUNCA versione o arquivo .env no Git
# ══════════════════════════════════════════════════════════════

# ── Banco de Dados ─────────────────────────────────────────────
DB_NAME=hamoa_obras
DB_USER=hamoa
DB_PASS=hamoa@2025_Troque_Esta_Senha

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASS=hamoa-redis@2025_Troque

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=hamoa-jwt-secret-muito-longo-e-seguro-troque-em-producao-2025
JWT_EXPIRES_IN=8h

# ── LDAP / Active Directory ────────────────────────────────────
LDAP_ENABLED=false
LDAP_URL=ldap://dc01.sua-empresa.local:389
LDAP_BASE_DN=DC=sua-empresa,DC=local
LDAP_DOMAIN=SUAEMPRESA
LDAP_BIND_DN=svc-hamoa@sua-empresa.local
LDAP_BIND_PASS=senha-do-servico-ldap

# ── SMTP / E-mail ──────────────────────────────────────────────
SMTP_HOST=smtp.sua-empresa.com.br
SMTP_PORT=587
SMTP_USER=noreply@sua-empresa.com.br
SMTP_PASS=senha-do-smtp
SMTP_FROM=HAMOA OBRAS <noreply@sua-empresa.com.br>

# ── Assinatura Eletrônica ──────────────────────────────────────
# Provedores suportados: d4sign | clicksign | docusign | autentique
ASSINATURA_PROVEDOR=d4sign
ASSINATURA_API_KEY=sua-api-key-aqui
ASSINATURA_API_SECRET=seu-api-secret-aqui
